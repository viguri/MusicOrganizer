# Music Organizer environment variables (example)
# Duplicate this file as .env and fill with your local values.

# --- Paths (optional) ---
MASTER_COLLECTION=YOUR_MASTER_COLLECTION_PATH
STYLES_DIR=YOUR_STYLES_DIR_PATH
NEW_RELEASES_DIR=YOUR_NEW_RELEASES_DIR_PATH

# --- OpenAI (optional: intelligent genre/subgenre reorganization) ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (optional: name cleaning model backend) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
